<Window x:Class="TestingWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestingWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="firstNumber" HorizontalAlignment="Left" Margin="49,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="31" TextChanged="TextBox_TextChanged" GotFocus="FirstNumber_GotFocus" LostFocus="FirstNumber_LostFocus" Foreground="Gray" Text="First Number"/>
        <TextBox x:Name="secondNumber" HorizontalAlignment="Left" Height="29" Margin="261,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="133" GotFocus="SecondNumber_GotFocus" LostFocus="SecondNumber_LostFocus" Foreground="Gray" Text="Second Number"/>
        <TextBox x:Name="sum" HorizontalAlignment="Left" Height="25" Margin="468,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="143" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <Label x:Name="Plus" Content="+" HorizontalAlignment="Left" Height="22" Margin="222,67,0,0" VerticalAlignment="Top" Width="21"/>
        <Label Content="=" HorizontalAlignment="Left" Height="29" Margin="422,58,0,0" VerticalAlignment="Top" Width="27"/>
        <Button Content="Calculate" HorizontalAlignment="Left" Height="30" Margin="261,125,0,0" VerticalAlignment="Top" Width="90" Click="Button_Click"/>

    </Grid>
</Window>

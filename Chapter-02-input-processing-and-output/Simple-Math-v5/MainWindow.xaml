<Window x:Class="Simple_Math_v5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Simple_Math_v5"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="firstNumber" HorizontalAlignment="Left" Margin="26,24,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="31" TextChanged="TextBox_TextChanged" GotFocus="FirstNumber_GotFocus" LostFocus="FirstNumber_LostFocus" Foreground="Gray" Text="First Number"/>
        <TextBox x:Name="secondNumber" HorizontalAlignment="Left" Height="28" Margin="26,74,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" GotFocus="SecondNumber_GotFocus" LostFocus="SecondNumber_LostFocus" Foreground="Gray" Text="Second Number"/>
        <TextBox x:Name="sum" HorizontalAlignment="Left" Height="25" Margin="468,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="143" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <Label x:Name="Plus" Content="+" HorizontalAlignment="Left" Height="22" Margin="106,140,0,0" VerticalAlignment="Top" Width="21" RenderTransformOrigin="-0.476,0.511"/>
        <Label Content="=" HorizontalAlignment="Left" Height="29" Margin="422,58,0,0" VerticalAlignment="Top" Width="27"/>
        <Button Content="Calculate" HorizontalAlignment="Left" Height="30" Margin="220,53,0,0" VerticalAlignment="Top" Width="90" Click="Button_Click"/>
        <TextBox x:Name="firstNumberCopy" HorizontalAlignment="Left" Height="25" Margin="26,140,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="46" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <TextBox x:Name="secondNumberCopy" HorizontalAlignment="Left" Height="25" Margin="142,140,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="48" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <Label x:Name="Plus_Copy3" Content="-" HorizontalAlignment="Left" Height="22" Margin="106,205,0,0" VerticalAlignment="Top" Width="21" RenderTransformOrigin="-0.476,0.511"/>
        <TextBox x:Name="firstNumberCopy1" HorizontalAlignment="Left" Height="25" Margin="26,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" Width="46" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <TextBox x:Name="secondNumberCopy1" HorizontalAlignment="Left" Height="25" Margin="142,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" Width="48" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <Label x:Name="Plus_Copy4" Content="*" HorizontalAlignment="Left" Height="22" Margin="106,261,0,0" VerticalAlignment="Top" Width="21" RenderTransformOrigin="-0.476,0.511"/>
        <TextBox x:Name="firstNumberCopy2" HorizontalAlignment="Left" Height="25" Margin="26,261,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="46" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <TextBox x:Name="secondNumberCopy2" HorizontalAlignment="Left" Height="25" Margin="142,261,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="48" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <Label x:Name="Plus_Copy5" Content="/" HorizontalAlignment="Left" Height="22" Margin="106,308,0,0" VerticalAlignment="Top" Width="21" RenderTransformOrigin="-0.476,0.511"/>
        <TextBox x:Name="firstNumberCopy3" HorizontalAlignment="Left" Height="25" Margin="26,308,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="46" IsReadOnly="True" Foreground="Black" Text="Sum"/>
        <TextBox x:Name="secondNumberCopy3" HorizontalAlignment="Left" Height="25" Margin="142,308,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="48" IsReadOnly="True" Foreground="Black" Text="Sum"/>

    </Grid>
</Window>

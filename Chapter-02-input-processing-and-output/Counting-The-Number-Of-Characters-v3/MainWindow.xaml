<Window x:Class="Counting_The_Number_Of_Characters_v3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Counting_The_Number_Of_Characters_v3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="userInput" HorizontalAlignment="Left" Margin="23,25,0,0" TextWrapping="Wrap" Text="Input anything eg. alphanumerals and special characters" VerticalAlignment="Top" Width="723" Height="32" GotFocus="UserInput_GotFocus" LostFocus="UserInput_LostFocus" TextChanged="TextBox_TextChanged" Foreground="Gray"/>
        <Label Content="Number of characters:" HorizontalAlignment="Left" Height="34" Margin="23,69,0,0" VerticalAlignment="Top" Width="136"/>
        <TextBox x:Name="count" HorizontalAlignment="Left" Height="31" Margin="151,72,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="181" IsReadOnly="True" />

    </Grid>
</Window>
